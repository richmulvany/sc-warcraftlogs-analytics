# ── Databricks ──────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token

# Unity Catalog target — all pipeline layers (bronze/silver/gold) share one
# catalog.schema. Layers are distinguished by table name prefix.
DATABRICKS_CATALOG=04_sdp
DATABRICKS_SCHEMA=warcraftlogs

# ── WarcraftLogs API ─────────────────────────────────────────────────────────
# OAuth2 client credentials — create a client at:
#   https://www.warcraftlogs.com/api/clients/
# These values MUST also be stored in the Databricks Secret Scope:
#   databricks secrets put-secret --scope pipeline-secrets --key wcl-client-id
#   databricks secrets put-secret --scope pipeline-secrets --key wcl-client-secret
WCL_CLIENT_ID=your-client-id-here
WCL_CLIENT_SECRET=your-client-secret-here

# ── Guild ─────────────────────────────────────────────────────────────────────
# These are passed as job widget parameters (set in databricks.yml variables).
GUILD_NAME=Singularity
GUILD_SERVER_SLUG=silvermoon
GUILD_SERVER_REGION=EU

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_NAME=WarcraftLogs Analytics
PIPELINE_MODE=development           # development | production

# ── Local CSV fallback export ────────────────────────────────────────────────
# Where scripts/dev/export_gold_tables.py writes local fallback CSVs.
EXPORT_OUTPUT_DIR=frontend/public/data

# ── Frontend ─────────────────────────────────────────────────────────────────
# Set in frontend/.env.local — base URL where published dashboard JSON is served from
# VITE_DASHBOARD_DATA_BASE_URL=https://data.sc-analytics.org/latest
