# ── Databricks ──────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token

# Unity Catalog target — all pipeline layers (bronze/silver/gold) share one
# catalog.schema. Layers are distinguished by table name prefix (e.g.
# bronze_guild_reports, silver_fight_events, gold_boss_progression).
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=pipeline_dev

# ── Source API ───────────────────────────────────────────────────────────────
# Replace with your data source credentials.
# These values should ALSO be stored in Databricks Secret Scope for pipeline use.
SOURCE_API_BASE_URL=https://your-api.example.com
SOURCE_API_KEY=your-api-key-here

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_NAME=medallion-pipeline
PIPELINE_MODE=development           # development | production

# ── Export ───────────────────────────────────────────────────────────────────
# Where nightly gold table exports are written (served as static JSON by frontend)
EXPORT_OUTPUT_DIR=data/exports

# ── Frontend ─────────────────────────────────────────────────────────────────
# Set in frontend/.env.local — base URL where exported JSON files are served from
# VITE_DATA_BASE_URL=https://richmulvany.github.io/databricks-pipeline-template/data
